rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Alphanumeric, safe string checking to prevent injection or abuse
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Schema Validation blueprint helper for games
    function isValidGameSession(data) {
      return data.id is string
        && data.id.size() <= 16
        && (data.status == 'setup' || data.status == 'waiting' || data.status == 'playing' || data.status == 'finished')
        && (data.mode == 'local_ai' || data.mode == 'local_pass' || data.mode == 'online')
        && data.board is list
        && data.board.size() == 100
        && data.players is list
        && data.players.size() >= 1
        && data.players.size() <= 4
        && data.currentTurnPlayerId is string
        && data.currentTurnPlayerId.size() <= 64
        && (data.activePieceIndex == null || data.activePieceIndex is int)
        && (data.winnerId == null || data.winnerId is string)
        && data.history is list
        && data.createdAt is int
        && data.lastUpdated is int;
    }

    // User Profile schema validation
    function isValidUserProfile(data) {
      return data.uid is string
        && data.uid.size() <= 64
        && data.displayName is string
        && data.displayName.size() <= 100
        && (data.photoUrl == null || data.photoUrl is string)
        && data.createdAt is int
        && (!('activeSessionId' in data) || data.activeSessionId == null || (data.activeSessionId is string && data.activeSessionId.size() <= 64));
    }

    // User Game History record validation
    function isValidHistoryItem(data) {
      return data.id is string
        && data.id.size() <= 64
        && data.won is bool
        && (data.mode == 'local_ai' || data.mode == 'local_pass' || data.mode == 'online')
        && data.capturedRed is int
        && data.capturedBlue is int
        && data.capturedGreen is int
        && data.capturedYellow is int
        && data.capturedPurple is int
        && data.totalPoints is int
        && data.playedAt is int;
    }

    // Match games collection with hardened constraints
    match /games/{gameId} {
      allow get: if isAuthenticated() && isValidId(gameId);

      allow create: if isAuthenticated()
        && isValidId(gameId)
        && isValidGameSession(request.resource.data)
        && request.resource.data.id == gameId;

      allow update: if isAuthenticated()
        && isValidId(gameId)
        && isValidGameSession(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && resource.data.status != 'finished';
    }

    // Match users profiles
    match /users/{userId} {
      allow get: if isAuthenticated() && isValidId(userId);
      allow create, update: if isAuthenticated()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUserProfile(request.resource.data);

      // Deeply secure subcollections
      match /gamesHistory/{historyId} {
        allow list, get: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated()
          && request.auth.uid == userId
          && isValidId(historyId)
          && isValidHistoryItem(request.resource.data);
        allow update, delete: if false; // Game history is immutable once written
      }
    }
  }
}
